{
  "name": "Mimms Museum Engine",
  "version": 1,
  "node_types": {
    "Topic": {
      "description": "Chosen artifact/person/theme to cover.",
      "immutable_content": true
    },
    "Source": {
      "description": "Web sources with URLs and notes.",
      "immutable_content": true
    },
    "Fact": {
      "description": "Atomic factual statements derived from sources.",
      "immutable_content": true
    },
    "Outline": {
      "description": "Structured plan for the article output.",
      "immutable_content": true
    },
    "Article": {
      "description": "Final HTML output for the museum site.",
      "immutable_content": true
    }
  },
  "edge_types": {
    "derived_from": { "description": "Node derived from upstream nodes." },
    "cites": { "description": "Node cites a source or fact." },
    "refines": { "description": "Node refines another node." },
    "summarizes": { "description": "Node summarizes a set of nodes." }
  },
  "agents": [
    {
      "id": "museum_topic_selector",
      "role": "Topic Selector",
      "permissions": { "web_search": false, "read_types": [], "write_types": ["Topic"] },
      "input_policy": { "max_nodes": 4 },
      "output_policy": {
        "outputs": [
          {
            "type": "Topic",
            "content_template": "TOPIC=auto_selected",
            "metadata": { "tags": ["museum", "topic"] }
          }
        ],
        "link_to_inputs": "derived_from",
        "cite_inputs": false
      }
    },
    {
      "id": "museum_researcher",
      "role": "Researcher",
      "permissions": { "web_search": true, "read_types": ["Topic"], "write_types": ["Source", "Fact"] },
      "input_policy": { "max_nodes": 6 },
      "output_policy": {
        "outputs": [
          {
            "type": "Source",
            "content_template": "Sources compiled by {agent_id} for inputs [{input_ids}].",
            "metadata": { "tags": ["museum", "source"] }
          },
          {
            "type": "Fact",
            "content_template": "Facts compiled by {agent_id} for inputs [{input_ids}].",
            "metadata": { "tags": ["museum", "fact"] }
          }
        ],
        "link_to_inputs": "derived_from",
        "cite_inputs": false
      }
    },
    {
      "id": "museum_outliner",
      "role": "Outliner",
      "permissions": { "web_search": false, "read_types": ["Fact"], "write_types": ["Outline"] },
      "input_policy": { "max_nodes": 10 },
      "output_policy": {
        "outputs": [
          {
            "type": "Outline",
            "content_template": "Outline prepared by {agent_id} from inputs [{input_ids}].",
            "metadata": { "tags": ["museum", "outline"] }
          }
        ],
        "link_to_inputs": "derived_from",
        "cite_inputs": false
      }
    },
    {
      "id": "museum_writer",
      "role": "Writer",
      "permissions": { "web_search": false, "read_types": ["Outline", "Fact"], "write_types": ["Article"] },
      "input_policy": { "max_nodes": 14 },
      "output_policy": {
        "outputs": [
          {
            "type": "Article",
            "content_template": "<main class=\"museum-body\"><div class=\"metadata\" style=\"display:none;\"><meta name=\"title\" content=\"Draft Museum Article\"><meta name=\"description\" content=\"Draft content.\"><meta name=\"tag\" content=\"Draft | Museum\"></div><p>Draft article by {agent_id} using inputs [{input_ids}].</p></main>",
            "metadata": { "tags": ["museum", "article", "draft"] }
          }
        ],
        "link_to_inputs": "derived_from",
        "cite_inputs": true
      }
    }
  ],
  "validators": {
    "schema": true,
    "format": {
      "Article": {
        "must_include": ["<main class=\"museum-body\">", "<div class=\"metadata\""]
      }
    },
    "citation_requirements": {
      "Article": { "edge_type": "cites", "min": 1 }
    }
  },
  "run_policy": {
    "agent_weights": {
      "museum_topic_selector": 2,
      "museum_researcher": 3,
      "museum_outliner": 2,
      "museum_writer": 1
    },
    "max_outputs_per_run": 2
  }
}
